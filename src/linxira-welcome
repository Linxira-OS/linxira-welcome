def read_json(path):
    try:
        with path.open(encoding="utf-8") as stream:
            return json.load(stream)
    except (OSError, json.JSONDecodeError):
        return None


def system_locale():
    locale = QLocale.system().name()
    if locale in LANGUAGES:
        return locale
    language = locale.split("_")[0]
    return language if language in LANGUAGES else "en"


def load_translation(language):
    translation = dict(TEXT["en"])
    localized = read_json(I18N_PATH / f"{language}.json")
    if isinstance(localized, dict):
        translation.update(localized)
    return translation


class WelcomeWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.settings = QSettings("Linxira", "Welcome")
        preferred_language = self.settings.value("language", system_locale())
        self.language = preferred_language if preferred_language in LANGUAGES else "en"
        self.text = load_translation(self.language)
        self.catalog = read_json(CATALOG_PATH)
        self.receipt = read_json(RECEIPT_PATH)
        self.update_status = read_json(UPDATE_STATUS_PATH)
        self.is_live = Path("/run/archiso").exists() or os.access(LIVE_INSTALLER, os.X_OK)
        self.setWindowTitle("Linxira Welcome")
        self.logo_icon = QIcon(str(LOGO_PATH)) if LOGO_PATH.is_file() else QIcon.fromTheme("linxira")
        self.setWindowIcon(self.logo_icon)
        self.setMinimumSize(760, 520)
        self.resize(960, 680)
        self._build_ui()

    def tr(self, key, **values):
        return self.text[key].format(**values)

    def _build_ui(self):
        root = QWidget()
        root.setObjectName("root")
        root_layout = QVBoxLayout(root)
        root_layout.setContentsMargins(0, 0, 0, 0)
        root_layout.setSpacing(0)
        root_layout.addWidget(self._header())

        body = QHBoxLayout()
        body.setContentsMargins(0, 0, 0, 0)
        body.setSpacing(0)
        self.navigation = QListWidget()
        self.navigation.setObjectName("navigation")
        self.navigation.setFixedWidth(230)
        self.navigation.setIconSize(QSize(22, 22))
        for label, icon in (
            (self.tr("home"), "go-home-symbolic"),
            (self.tr("status"), "dialog-information"),
            (self.tr("help"), "help-contents"),
        ):
            item = QListWidgetItem(QIcon.fromTheme(icon), label)
            item.setSizeHint(QSize(210, 48))
            self.navigation.addItem(item)

        self.pages = QStackedWidget()
        self.pages.addWidget(self._home_page())
        self.pages.addWidget(self._status_page())
        self.pages.addWidget(self._help_page())
        self.navigation.currentRowChanged.connect(self.pages.setCurrentIndex)
        self.navigation.setCurrentRow(0)
        body.addWidget(self.navigation)
        body.addWidget(self.pages, 1)
        root_layout.addLayout(body, 1)
        self.setCentralWidget(root)
        self._apply_style()

    def _header(self):
        frame = QFrame()
        frame.setObjectName("header")
        layout = QHBoxLayout(frame)
        layout.setContentsMargins(28, 18, 28, 18)
        icon = QLabel()
        icon.setPixmap(self.logo_icon.pixmap(52, 52))
        icon.setFixedSize(56, 56)
        layout.addWidget(icon)

        titles = QVBoxLayout()
        title = QLabel("Linxira OS")
        title.setObjectName("productTitle")
        subtitle = QLabel(self.tr("subtitle_live" if self.is_live else "subtitle_installed"))
        subtitle.setObjectName("subtitle")
        titles.addWidget(title)
        titles.addWidget(subtitle)
        layout.addLayout(titles)
        layout.addStretch()

        language = QComboBox()
        language.setObjectName("languageSelector")
        for code, name in LANGUAGES.items():
            language.addItem(name, code)
        language.setCurrentIndex(language.findData(self.language))
        language.currentIndexChanged.connect(
            lambda index: self._set_language(language.itemData(index))
        )
        layout.addWidget(language)
        return frame

    def _set_language(self, language):
        if not language or language == self.language:
            return
        current_page = self.navigation.currentRow()
        self.language = language
        self.text = load_translation(language)
        self.settings.setValue("language", language)
        self._build_ui()
        self.navigation.setCurrentRow(current_page)

    def _page(self, title):
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setFrameShape(QFrame.NoFrame)
        content = QWidget()
        layout = QVBoxLayout(content)
        layout.setContentsMargins(32, 28, 32, 32)
        layout.setSpacing(16)
        heading = QLabel(title)
        heading.setObjectName("pageTitle")
        layout.addWidget(heading)
        scroll.setWidget(content)
        return scroll, layout

    def _home_page(self):
        page, layout = self._page(self.tr("home"))
        if self.is_live:
            banner = QFrame()
            banner.setObjectName("installBanner")
            row = QHBoxLayout(banner)
            row.setContentsMargins(22, 18, 22, 18)
            copy = QVBoxLayout()
            title = QLabel(self.tr("live_title"))
            title.setObjectName("sectionTitle")
            body = QLabel(self.tr("live_body"))
            body.setWordWrap(True)
            copy.addWidget(title)
            copy.addWidget(body)
            row.addLayout(copy, 1)
            row.addWidget(self._button(self.tr("install"), "drive-harddisk", "installer", primary=True))
            layout.addWidget(banner)
        else:
            layout.addWidget(self._section_title(self.tr("workstation_status")))
            status = QGridLayout()
            status.setSpacing(12)
            health, completion = self._installed_state()
            status.addWidget(self._status_tile(self.tr("health"), self.tr(health)), 0, 0)
            status.addWidget(self._status_tile(self.tr("first_completion"), self.tr(completion)), 0, 1)
            layout.addLayout(status)

        layout.addWidget(self._section_title(self.tr("launchers")))
        actions = QGridLayout()
        actions.setHorizontalSpacing(12)
        actions.setVerticalSpacing(12)
        actions.addWidget(self._action_tile(self.tr("open_software"), "system-software-install", "package_center"), 0, 0)
        actions.addWidget(self._action_tile(self.tr("open_components"), "preferences-system-software", "component_manager"), 0, 1)
        actions.addWidget(self._action_tile(self.tr("open_config"), "utilities-terminal", "config"), 1, 0)
        actions.addWidget(self._action_tile(self.tr("open_settings"), "preferences-system", "settings"), 1, 1)
        if not self.is_live:
            actions.addWidget(self._action_tile(self.tr("open_update"), "system-software-update", "update"), 2, 0)
            actions.addWidget(self._action_tile(self.tr("open_gaming"), "applications-games", "gaming"), 2, 1)
            actions.addWidget(self._action_tile(self.tr("open_hardware"), "preferences-devices", "hardware"), 3, 0)
            actions.addWidget(self._action_tile(self.tr("open_recovery"), "tools-report-bug", "recovery"), 3, 1)
        layout.addLayout(actions)
        layout.addStretch()
        return page

    def _status_page(self):
        page, layout = self._page(self.tr("status"))
        layout.addWidget(self._section_title(self.tr("workstation_status")))
        status = QGridLayout()
        status.setSpacing(12)
        release = self.catalog.get("release", "-") if isinstance(self.catalog, dict) else "-"
        reviewed = self.catalog.get("reviewed", "-") if isinstance(self.catalog, dict) else "-"
        network = self.tr("connected") if self._network_connected() else self.tr("offline")
        catalog_status = self.tr("catalog_available") if isinstance(self.catalog, dict) else self.tr("catalog_unavailable")
        receipt_status = self.receipt.get("status", self.tr("receipt_missing")) if isinstance(self.receipt, dict) else self.tr("receipt_missing")
        update_count, last_check, reboot_required = self._update_state()
        for column, (label, value) in enumerate(
            (
                (self.tr("release"), release),
                (self.tr("kernel"), platform.release()),
                (self.tr("network"), network),
                (self.tr("catalog_review"), f"{catalog_status} / {reviewed}"),
                (self.tr("receipt_status"), receipt_status),
                (self.tr("available_updates"), update_count),
                (self.tr("last_update_check"), last_check),
                (self.tr("reboot_required"), reboot_required),
            )
        ):
            status.addWidget(self._status_tile(label, value), column // 3, column % 3)
        layout.addLayout(status)

        layout.addWidget(self._section_title(self.tr("selection")))
        selection = QFrame()
        selection.setObjectName("panel")
        selection_layout = QVBoxLayout(selection)
        selected = []
        if isinstance(self.receipt, dict):
            profiles = self.receipt.get("profiles", [])
            applications = self.receipt.get("applications", [])
            if isinstance(profiles, list) and isinstance(applications, list):
                selected = profiles + applications
        selection_layout.addWidget(QLabel(", ".join(selected) if selected else self.tr("selection_none")))
        layout.addWidget(selection)

        layout.addStretch()
        return page

    def _help_page(self):
        page, layout = self._page(self.tr("help"))
        layout.addWidget(self._section_title(self.tr("guidance")))
        guidance = QFrame()
        guidance.setObjectName("panel")
        guidance_layout = QVBoxLayout(guidance)
        guidance_text = QLabel(self.tr("guidance_body"))
        guidance_text.setWordWrap(True)
        guidance_layout.addWidget(guidance_text)
        guidance_actions = QHBoxLayout()
        guidance_actions.addWidget(self._link_button(self.tr("view_news"), "view-calendar-news", "arch_news"))
        guidance_actions.addWidget(self._link_button(self.tr("open_wiki"), "help-contents", "wiki"))
        guidance_actions.addStretch()
        guidance_layout.addLayout(guidance_actions)
        layout.addWidget(guidance)
        layout.addWidget(self._section_title(self.tr("docs")))
        layout.addWidget(self._link_row(self.tr("wiki"), "help-contents", "wiki"))
        layout.addWidget(self._link_row(self.tr("arch_wiki"), "internet-web-browser", "arch_wiki"))
        layout.addWidget(self._link_row(self.tr("arch_news"), "view-calendar-news", "arch_news"))
        layout.addWidget(self._section_title(self.tr("project")))
        layout.addWidget(self._link_row(self.tr("website"), "internet-web-browser", "website"))
        layout.addWidget(self._link_row(self.tr("github"), "applications-development", "github"))
        layout.addStretch()

        show_login = QCheckBox(self.tr("show_login"))
        show_login.setChecked(self.settings.value("showAtLogin", True, type=bool))
        show_login.toggled.connect(lambda checked: self.settings.setValue("showAtLogin", checked))
        layout.addWidget(show_login)
        return page

    def _installed_state(self):
        if not isinstance(self.receipt, dict):
            return "health_attention", "completion_unknown"
        receipt_status = self.receipt.get("status")
        if receipt_status in ("installed", "none"):
            health = "health_ready" if isinstance(self.catalog, dict) else "health_attention"
            return health, "completion_complete"
        if receipt_status == "deferred":
            return "health_attention", "completion_pending"
        return "health_attention", "completion_unknown"

    def _update_state(self):
        if not isinstance(self.update_status, dict) or self.update_status.get("version") != 1:
            unknown = self.tr("unknown")
            return unknown, unknown, unknown
        count = self.update_status.get("available_update_count")
        last_check = self.update_status.get("last_check")
        reboot = self.update_status.get("reboot_required")
        count_text = str(count) if isinstance(count, int) and not isinstance(count, bool) and count >= 0 else self.tr("unknown")
        last_check_text = last_check if isinstance(last_check, str) and last_check else self.tr("unknown")
        reboot_text = self.tr("yes") if reboot is True else self.tr("no") if reboot is False else self.tr("unknown")
        return count_text, last_check_text, reboot_text

    def _section_title(self, text):
        label = QLabel(text)
        label.setObjectName("sectionTitle")
        return label

    def _status_tile(self, label, value):
        frame = QFrame()
        frame.setObjectName("statusTile")
        layout = QVBoxLayout(frame)
        layout.setContentsMargins(14, 11, 14, 11)
        key = QLabel(label)
        key.setObjectName("muted")
        result = QLabel(value)
        result.setObjectName("statusValue")
        result.setWordWrap(True)
        layout.addWidget(key)
        layout.addWidget(result)
        return frame

    def _network_connected(self):
        network_root = Path("/sys/class/net")
        try:
            return any(
                interface.name != "lo"
                and (interface / "operstate").read_text(encoding="utf-8").strip() == "up"
                for interface in network_root.iterdir()
            )
        except OSError:
            return False

    def _button(self, text, icon, app, primary=False):
        button = QPushButton(QIcon.fromTheme(icon), text)
        button.setProperty("primary", primary)
        executable = APPS[app][0]
        button.setEnabled(shutil.which(executable) is not None or os.access(executable, os.X_OK))
        button.clicked.connect(lambda: self._launch_app(app, text))
        return button

    def _action_tile(self, text, icon, app):
        button = self._button(text, icon, app)
        button.setObjectName("actionTile")
        button.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)
        button.setMinimumHeight(72)
        return button

    def _link_row(self, text, icon, link):
        button = self._link_button(text, icon, link)
        button.setObjectName("linkRow")
        button.setMinimumHeight(50)
        return button

    def _link_button(self, text, icon, link):
        button = QPushButton(QIcon.fromTheme(icon), text)
        button.clicked.connect(lambda: QDesktopServices.openUrl(QUrl(LINKS[link])))
        return button

    def _launch_app(self, app, display_name):
        executable, arguments = APPS[app]
        if not QProcess.startDetached(executable, arguments):
            QMessageBox.warning(self, "Linxira Welcome", self.tr("launch_error", name=display_name))

    def _apply_style(self):
        self.setStyleSheet(
            """
            QWidget#root { background: palette(window); }
            QFrame#header { background: palette(base); border-bottom: 1px solid palette(mid); }
            QLabel#productTitle { font-size: 23px; font-weight: 700; }
            QLabel#subtitle { color: #b8c0c2; }
            QLabel#muted { color: #9aa6a8; }
            QLabel#pageTitle { font-size: 22px; font-weight: 650; }
            QLabel#sectionTitle { font-size: 15px; font-weight: 650; }
            QListWidget#navigation { background: palette(alternate-base); border: 0; padding: 14px 8px; }
            QListWidget#navigation::item { border-radius: 5px; padding: 8px 12px; }
            QListWidget#navigation::item:selected { background: #147f78; color: white; }
            QFrame#panel { background: palette(base); border: 1px solid palette(midlight); border-radius: 6px; }
            QFrame#statusTile { background: palette(base); border: 1px solid palette(midlight); border-radius: 5px; }
            QLabel#statusValue { font-size: 14px; font-weight: 600; }
            QFrame#installBanner { background: #123f3d; color: white; border-left: 4px solid #20b8a6; border-radius: 6px; }
            QFrame#installBanner QLabel { color: white; }
            QPushButton { min-height: 34px; padding: 5px 13px; border-radius: 5px; }
            QPushButton[primary="true"] { background: #147f78; color: white; border: 1px solid #147f78; font-weight: 600; }
            QPushButton[primary="true"]:hover { background: #106c66; }
            QPushButton#actionTile { text-align: left; padding: 12px 18px; background: palette(base); border: 1px solid palette(midlight); }
            QPushButton#actionTile:hover, QPushButton#linkRow:hover { border-color: #147f78; }
            QPushButton#linkRow { text-align: left; padding: 8px 14px; background: palette(base); border: 1px solid palette(midlight); }
            QComboBox#languageSelector { min-width: 150px; min-height: 34px; padding: 3px 8px; }
            """
        )

def main():
    app = QApplication(sys.argv)
    app.setApplicationName("Linxira Welcome")
    app.setOrganizationName("Linxira")
    settings = QSettings("Linxira", "Welcome")
    if "--autostart" in sys.argv and not settings.value("showAtLogin", True, type=bool):
        return 0
    window = WelcomeWindow()
    window.show()
    return app.exec()


if __name__ == "__main__":
    raise SystemExit(main())
